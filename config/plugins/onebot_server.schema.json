{
  "plugin_name": "onebot_server",
  "fields": [
    {
      "name": "enabled",
      "type": "boolean",
      "required": false,
      "description": "是否启用插件",
      "default": false,
      "example": false
    },
    {
      "name": "host",
      "type": "string",
      "required": false,
      "description": "绑定的 Host",
      "default": "0.0.0.0",
      "example": "0.0.0.0"
    },
    {
      "name": "port",
      "type": "integer",
      "required": false,
      "description": "绑定的端口",
      "default": 8081,
      "example": 8081
    },
    {
      "name": "access_token",
      "type": "string",
      "required": false,
      "description": "访问令牌，为空则不验证",
      "default": "",
      "example": "your_secret_token"
    }
  ]
}

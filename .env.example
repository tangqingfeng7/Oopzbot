# Copy this file to .env for Linux one-click startup.

# Optional Python bootstrap settings
# PYTHON_BIN=python3
# VENV_DIR=.venv
# SKIP_INSTALL=0
# SKIP_PLAYWRIGHT_INSTALL=0

# Clash / Mihomo subscription startup
CLASH_AUTO_START=1
CLASH_SUBSCRIPTION_URL="https://example.com/subscribe"
# CLASH_KERNEL_BIN=mihomo
CLASH_MIXED_PORT=7890
CLASH_SOCKS_PORT=7891
# CLASH_EXTERNAL_CONTROLLER=127.0.0.1:9090
# CLASH_SECRET=
# CLASH_ALLOW_LAN=false
# CLASH_BIND_ADDRESS=*
# CLASH_LOG_LEVEL=info

# Bot proxy target. Leave unset to use http://127.0.0.1:${CLASH_MIXED_PORT}
# BOT_OOPZ_PROXY=http://127.0.0.1:7890
